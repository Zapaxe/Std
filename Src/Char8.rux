module Std {
    func ToString(value: char8) -> String {
        var buf: char8[1];
        buf[0] = value;
        return String::From(buf.data, 1);
    }

    extend char8 : Display {
        func ToString(self) -> String {            
            return ToString(*self);
        }
    }
}
