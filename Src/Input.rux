@[Target("BSD")]
import BSD::{
    IsError,
    Read,
    Stdin
};

@[Target("Illumos")]
import Illumos::{
    IsError,
    Read,
    Stdin
};

@[Target("Linux")]
import Linux::{
    IsError,
    Read,
    Stdin
};

/*@[Target("MacOS")]
import MacOS::{
    Func1,
    Func2,
    Func3
};*/

@[Target("Windows")]
import Windows::{
    GetStdHandle,
    StdHandle,
    ReadFile,
};

import Std::Memory::{ Alloc, Copy };

module Std::Io {
    const MaxInputLength: uint = 4096;

    @[Target("BSD")]
    func ReadLine() -> String {
        var buf: char8[MaxInputLength];
        let count = Read(Stdin, buf.data, MaxInputLength);
        if IsError(count) || count == 0i64 {
            return String { data: null, length: 0 };
        }

        var len = count as uint;
        if len > 0 && buf[len - 1] == c8'\n' {
            len--;
        }
        if len > 0 && buf[len - 1] == c8'\r' {
            len--;
        }
        if len == 0 {
            return String { data: null, length: 0 };
        }

        let ptr = Alloc(len) as *char8;
        Copy(ptr, buf.data, len);
        return String { data: ptr, length: len };
    }

    @[Target("Illumos")]
    func ReadLine() -> String {
        var buf: char8[MaxInputLength];
        let count = Read(Stdin, buf.data, MaxInputLength);
        if IsError(count) || count == 0i64 {
            return String { data: null, length: 0 };
        }

        var len = count as uint;
        if len > 0 && buf[len - 1] == c8'\n' {
            len--;
        }
        if len > 0 && buf[len - 1] == c8'\r' {
            len--;
        }
        if len == 0 {
            return String { data: null, length: 0 };
        }

        let ptr = Alloc(len) as *char8;
        Copy(ptr, buf.data, len);
        return String { data: ptr, length: len };
    }

    @[Target("Linux")]
    func ReadLine() -> String {
        var buf: char8[MaxInputLength];
        let count = Read(Stdin, buf.data, MaxInputLength);
        if IsError(count) || count == 0i64 {
            return String { data: null, length: 0 };
        }

        var len = count as uint;
        if len > 0 && buf[len - 1] == c8'\n' {
            len--;
        }
        if len > 0 && buf[len - 1] == c8'\r' {
            len--;
        }
        if len == 0 {
            return String { data: null, length: 0 };
        }

        let ptr = Alloc(len) as *char8;
        Copy(ptr, buf.data, len);
        return String { data: ptr, length: len };
    }

    @[Target("MacOS")]
    func ReadLine() -> String {
        return String { data: null, length: 0 };
    }

    @[Target("Windows")]
    func ReadLine() -> String {
        var buf: char8[MaxInputLength];
        var bytesRead: uint32 = 0;
        let handle: *opaque = GetStdHandle(StdHandle::Input as uint32);
        if ReadFile(handle, buf.data, MaxInputLength as uint32, &bytesRead, null) == 0 {
            return String { data: null, length: 0 };
        }
        var len = bytesRead as uint;
        if len > 0 && buf[len - 1] == c8'\n' {
            len--;
        }
        if len > 0 && buf[len - 1] == c8'\r' {
            len--;
        }
        if len == 0 {
            return String { data: null, length: 0 };
        }
        let ptr = Alloc(len) as *char8;
        Copy(ptr, buf.data, len);
        return String { data: ptr, length: len };
    }
}
