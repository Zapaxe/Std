@[Target("BSD")]
import BSD::{
    IsError,
    Mmap,
    Munmap,
    MAP_ANONYMOUS,
    MAP_PRIVATE,
    PROT_READ,
    PROT_WRITE
};

@[Target("Illumos")]
import Illumos::{
    IsError,
    Mmap,
    Munmap,
    MAP_ANONYMOUS,
    MAP_PRIVATE,
    PROT_READ,
    PROT_WRITE
};

@[Target("Linux")]
import Linux::{
    IsError,
    Mmap,
    Munmap,
    MAP_ANONYMOUS,
    MAP_PRIVATE,
    PROT_READ,
    PROT_WRITE
};

@[Target("MacOS")]
import MacOS::{
    GetProcessHeap,
    HeapAlloc,
    HeapFree
};

@[Target("Windows")]
import Windows::{
    HeapAlloc,
    HeapReAlloc,
    HeapFree,
    GetProcessHeap,
    RtlCompareMemory,
    RtlFillMemory,
    RtlZeroMemory,
    RtlCopyMemory
};

module Std::Memory {
    const HeaderSize: uint = 8;

    @[Target("BSD")]
    func Alloc(size: uint) -> *opaque {
        let total = size + HeaderSize;
        let mapping = Mmap(null, total, PROT_READ | PROT_WRITE, MAP_PRIVATE | MAP_ANONYMOUS, -1i32, 0u64);
        if IsError(mapping) {
            return null;
        }

        let header = mapping as *uint;
        *header = size;
        return (header + 1) as *opaque;
    }

    @[Target("Illumos")]
    func Alloc(size: uint) -> *opaque {
        let total = size + HeaderSize;
        let mapping = Mmap(null, total, PROT_READ | PROT_WRITE, MAP_PRIVATE | MAP_ANONYMOUS, -1i32, 0u64);
        if IsError(mapping) {
            return null;
        }

        let header = mapping as *uint;
        *header = size;
        return (header + 1) as *opaque;
    }

    @[Target("Linux")]
    func Alloc(size: uint) -> *opaque {
        let total = size + HeaderSize;
        let mapping = Mmap(null, total, PROT_READ | PROT_WRITE, MAP_PRIVATE | MAP_ANONYMOUS, -1i32, 0u64);
        if IsError(mapping) {
            return null;
        }

        let header = mapping as *uint;
        *header = size;
        return (header + 1) as *opaque;
    }

    @[Target("MacOS")]
    func Alloc(size: uint) -> *opaque {
        return HeapAlloc(GetProcessHeap(), 0, size);
    }

    @[Target("Windows")]
    func Alloc(size: uint) -> *opaque {
        return HeapAlloc(GetProcessHeap(), 0, size);
    }

    @[Target("BSD")]
    func Realloc(ptr: *opaque, size: uint) -> *opaque {
        if ptr == null {
            return Alloc(size);
        }
        if size == 0 {
            Free(ptr);
            return null;
        }

        let header = (ptr as *uint) - 1;
        let oldSize = *header;
        let newPtr = Alloc(size);
        if newPtr == null {
            return null;
        }

        let copySize = oldSize < size ? oldSize : size;
        Copy(newPtr, ptr, copySize);
        Free(ptr);
        return newPtr;
    }

    @[Target("Illumos")]
    func Realloc(ptr: *opaque, size: uint) -> *opaque {
        if ptr == null {
            return Alloc(size);
        }
        if size == 0 {
            Free(ptr);
            return null;
        }

        let header = (ptr as *uint) - 1;
        let oldSize = *header;
        let newPtr = Alloc(size);
        if newPtr == null {
            return null;
        }

        let copySize = oldSize < size ? oldSize : size;
        Copy(newPtr, ptr, copySize);
        Free(ptr);
        return newPtr;
    }

    @[Target("Linux")]
    func Realloc(ptr: *opaque, size: uint) -> *opaque {
        if ptr == null {
            return Alloc(size);
        }
        if size == 0 {
            Free(ptr);
            return null;
        }

        let header = (ptr as *uint) - 1;
        let oldSize = *header;
        let newPtr = Alloc(size);
        if newPtr == null {
            return null;
        }

        let copySize = oldSize < size ? oldSize : size;
        Copy(newPtr, ptr, copySize);
        Free(ptr);
        return newPtr;
    }

    @[Target("MacOS")]
    func Realloc(ptr: *opaque, size: uint) -> *opaque {
        return null;
    }

    @[Target("Windows")]
    func Realloc(ptr: *opaque, size: uint) -> *opaque {
        return HeapReAlloc(GetProcessHeap(), 0, ptr, size);
    }

    @[Target("BSD")]
    func Free(ptr: *opaque) {
        if ptr == null {
            return;
        }

        let header = (ptr as *uint) - 1;
        Munmap(header as *opaque, *header + HeaderSize);
    }

    @[Target("Illumos")]
    func Free(ptr: *opaque) {
        if ptr == null {
            return;
        }

        let header = (ptr as *uint) - 1;
        Munmap(header as *opaque, *header + HeaderSize);
    }

    @[Target("Linux")]
    func Free(ptr: *opaque) {
        if ptr == null {
            return;
        }

        let header = (ptr as *uint) - 1;
        Munmap(header as *opaque, *header + HeaderSize);
    }

    @[Target("MacOS")]
    func Free(ptr: *opaque) {
        HeapFree(GetProcessHeap(), 0, ptr);
    }

    @[Target("Windows")]
    func Free(ptr: *opaque) {
        HeapFree(GetProcessHeap(), 0, ptr);
    }

    @[Target("BSD")]
    func Set(ptr: *opaque, size: uint, value: int32) {
        let p = ptr as *char8;
        var i: uint = 0;
        while i < size {
            *(p + i) = value as char8;
            i++;
        }
    }

    @[Target("Illumos")]
    func Set(ptr: *opaque, size: uint, value: int32) {
        let p = ptr as *char8;
        var i: uint = 0;
        while i < size {
            *(p + i) = value as char8;
            i++;
        }
    }

    @[Target("Linux")]
    func Set(ptr: *opaque, size: uint, value: int32) {
        let p = ptr as *char8;
        var i: uint = 0;
        while i < size {
            *(p + i) = value as char8;
            i++;
        }
    }

    @[Target("MacOS")]
    func Set(ptr: *opaque, size: uint, value: int32) {
    }

    @[Target("Windows")]
    func Set(ptr: *opaque, size: uint, value: int32) {
        RtlFillMemory(ptr, size, value);
    }

    @[Target("BSD")]
    func Zero(ptr: *opaque, size: uint) {
        Set(ptr, size, 0);
    }

    @[Target("Illumos")]
    func Zero(ptr: *opaque, size: uint) {
        Set(ptr, size, 0);
    }

    @[Target("Linux")]
    func Zero(ptr: *opaque, size: uint) {
        Set(ptr, size, 0);
    }

    @[Target("MacOS")]
    func Zero(ptr: *opaque, size: uint) {
    }

    @[Target("Windows")]
    func Zero(ptr: *opaque, size: uint) {
        RtlZeroMemory(ptr, size);
    }

    @[Target("BSD")]
    func Compare(lhs: *const opaque, rhs: *const opaque, length: uint) -> uint {
        let l = lhs as *const char8;
        let r = rhs as *const char8;
        var i: uint = 0;
        while i < length {
            if *(l + i) != *(r + i) {
                return i;
            }
            i++;
        }
        return length;
    }

    @[Target("Illumos")]
    func Compare(lhs: *const opaque, rhs: *const opaque, length: uint) -> uint {
        let l = lhs as *const char8;
        let r = rhs as *const char8;
        var i: uint = 0;
        while i < length {
            if *(l + i) != *(r + i) {
                return i;
            }
            i++;
        }
        return length;
    }

    @[Target("Linux")]
    func Compare(lhs: *const opaque, rhs: *const opaque, length: uint) -> uint {
        let l = lhs as *const char8;
        let r = rhs as *const char8;
        var i: uint = 0;
        while i < length {
            if *(l + i) != *(r + i) {
                return i;
            }
            i++;
        }
        return length;
    }

    @[Target("MacOS")]
    func Compare(lhs: *const opaque, rhs: *const opaque, length: uint) -> uint {
        return length;
    }

    @[Target("Windows")]
    func Compare(lhs: *const opaque, rhs: *const opaque, length: uint) -> uint {
        return RtlCompareMemory(lhs, rhs, length);
    }

    @[Target("BSD")]
    func Copy(dest: *opaque, src: *const opaque, length: uint) {
        let d = dest as *char8;
        let s = src as *const char8;
        var i: uint = 0;
        while i < length {
            *(d + i) = *(s + i);
            i++;
        }
    }

    @[Target("Illumos")]
    func Copy(dest: *opaque, src: *const opaque, length: uint) {
        let d = dest as *char8;
        let s = src as *const char8;
        var i: uint = 0;
        while i < length {
            *(d + i) = *(s + i);
            i++;
        }
    }

    @[Target("MacOS")]
    func Copy(dest: *opaque, src: *const opaque, length: uint) {
    }

    @[Target("Linux")]
    func Copy(dest: *opaque, src: *const opaque, length: uint) {
        let d = dest as *char8;
        let s = src as *const char8;
        var i: uint = 0;
        while i < length {
            *(d + i) = *(s + i);
            i++;
        }
    }

    @[Target("MacOS")]
    func Copy(dest: *opaque, src: *const opaque, length: uint) {
    }

    @[Target("Windows")]
    func Copy(dest: *opaque, src: *const opaque, length: uint) {
        RtlCopyMemory(dest, src, length);
    }
}
